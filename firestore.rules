rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Apenas Cloud Functions (server-side) leem e escrevem em 'mentoradas'.
    // O frontend nunca acessa o Firestore diretamente — passa sempre pelas Functions.
    match /mentoradas/{uid} {
      allow read, write: if false;
    }

    // Conteúdo do Clube — leitura e escrita apenas via admin (Cloud Functions usam admin SDK).
    match /clubeContent/{id} {
      allow read:  if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // CRM Pipeline — somente admin acessa diretamente.
    match /leads/{id} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Nenhuma outra coleção é acessível pelo cliente.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
